# ─────────── Cubase-Projekt: Git-Empfehlungen ───────────
# .cpr-Dateien sind XML-Text (keine Binärdaten), komprimieren gut
# und lassen sich prima mit Git versionieren:
#
#   git init && git add .gitignore *.cpr _Docs/ && git commit -m "Initial"
#
# Audio, Mixdown, Video etc. werden bewusst ignoriert (zu groß).

# Cubase-Generated Files
Audio/
Edits/
Images/
Track Pictures/
Auto Saves/

# Mixdown — Verzeichnisstruktur getrackt, Audio-Inhalte ignoriert
Mixdown/*
!Mixdown/.gitkeep
!Mixdown/Mixes/
!Mixdown/Stems/
!Mixdown/Masters/
Mixdown/Mixes/*
!Mixdown/Mixes/.gitkeep
Mixdown/Stems/*
!Mixdown/Stems/.gitkeep
Mixdown/Masters/*
!Mixdown/Masters/.gitkeep

# Large Media (not in Git — use external storage)
# Verzeichnisse mit .gitkeep getrackt, Inhalte ignoriert
_Video/*
!_Video/.gitkeep
_Artwork/*
!_Artwork/.gitkeep
_Refs/*
!_Refs/.gitkeep
_Sources/*
!_Sources/.gitkeep

# macOS
.DS_Store
