# ─────────── Cubase-Projekt: Git-Empfehlungen ───────────
# .cpr-Dateien sind binär (RIFF-Container). Cubase 15 Pro
# hat eigene Versionierung (Ctrl+Alt+S). Nur Doku & Text landen in Git.

# Cubase-Projekte (Cubase versioniert selbst)
*.cpr

# Cubase-Generated Files
Audio/
Edits/
Images/
Track Pictures/
Auto Saves/

# Mixdown — Verzeichnisstruktur getrackt, Audio-Inhalte ignoriert
Mixdown/*
!Mixdown/.gitkeep
!Mixdown/Mixes/
!Mixdown/Stems/
!Mixdown/Masters/
Mixdown/Mixes/*
!Mixdown/Mixes/.gitkeep
Mixdown/Stems/*
!Mixdown/Stems/.gitkeep
Mixdown/Masters/*
!Mixdown/Masters/.gitkeep

# Large Media (not in Git — use external storage)
# Verzeichnisse mit .gitkeep getrackt, Inhalte ignoriert
_Video/*
!_Video/.gitkeep
_Artwork/*
!_Artwork/.gitkeep
_Refs/*
!_Refs/.gitkeep
_Sources/*
!_Sources/.gitkeep

# macOS
.DS_Store
